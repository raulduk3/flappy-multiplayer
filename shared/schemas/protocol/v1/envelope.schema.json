{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/envelope.schema.json",
  "title": "Protocol Envelope",
  "type": "object",
  "description": "Top-level message envelope for Flappy real-time protocol v1. Includes all message variants. Adding new message types requires MINOR (optional) or MAJOR (breaking) bump per SemVer rules documented in README.",
  "oneOf": [
    {"$ref": "#/definitions/Hello"},
    {"$ref": "#/definitions/Welcome"},
    {"$ref": "#/definitions/Error"},
    {"$ref": "#/definitions/Input"},
    {"$ref": "#/definitions/Engrave"},
    {"$ref": "#/definitions/Snapshot"},
    {"$ref": "#/definitions/RunStart"},
    {"$ref": "#/definitions/RunEnd"},
    {"$ref": "#/definitions/CapabilitiesRequest"},
    {"$ref": "#/definitions/CapabilitiesResponse"}
  ],
  "definitions": {
    "ProtocolVersion": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "Hello": {
      "type": "object",
      "required": ["type", "protocol_version"],
      "properties": {
        "type": {"const": "hello"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "client_info": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "client": {"type": "string"},
            "version": {"type": "string"}
          }
        }
      },
      "additionalProperties": false
    },
    "Welcome": {
      "type": "object",
      "required": ["type", "protocol_version"],
      "properties": {
        "type": {"const": "welcome"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "server_info": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "version": {"type": "string"}
          }
        }
      },
      "additionalProperties": false
    },
    "Error": {
      "type": "object",
      "required": ["type", "protocol_version", "code", "message"],
      "properties": {
        "type": {"const": "error"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "code": {
          "type": "string",
          "enum": [
            "validation_error",
            "rate_limit_exceeded",
            "incompatible_protocol",
            "unauthorized",
            "internal_error",
            "bad_request",
            "resource_exhausted",
            "not_found",
            "conflict",
            "unsupported_action"
          ]
        },
        "message": {"type": "string"},
        "details": {"type": "object"},
        "upgrade_hint": {"type": "string"}
      },
      "additionalProperties": false
    },
    "Input": {
      "type": "object",
      "required": ["type", "protocol_version", "seq", "action", "ts"],
      "properties": {
        "type": {"const": "input"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "seq": {"type": "integer", "minimum": 0},
        "action": {"type": "string", "enum": ["flap", "start", "join"]},
        "ts": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "Engrave": {
      "type": "object",
      "required": ["type", "protocol_version", "run_id", "name"],
      "properties": {
        "type": {"const": "engrave"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "run_id": {"type": "string"},
        "name": {"type": "string", "minLength": 1, "maxLength": 24}
      },
      "additionalProperties": false
    },
    "PlayerState": {
      "type": "object",
      "required": ["id", "x", "y", "vx", "vy", "state"],
      "properties": {
        "id": {"type": "string"},
        "x": {"type": "number"},
        "y": {"type": "number"},
        "vx": {"type": "number"},
        "vy": {"type": "number"},
        "state": {"type": "string", "enum": ["idle", "alive", "dead"]}
      },
      "additionalProperties": false
    },
    "PipesWindow": {
      "type": "object",
      "required": ["x", "gapY", "gapH", "id"],
      "properties": {
        "x": {"type": "array", "items": {"type": "number"}, "maxItems": 50},
        "gapY": {"type": "array", "items": {"type": "number"}, "maxItems": 50},
        "gapH": {"type": "array", "items": {"type": "number", "minimum": 0}, "maxItems": 50},
        "id": {"type": "array", "items": {"type": "string"}, "maxItems": 50}
      },
      "additionalProperties": false
    },
    "LeaderboardEntry": {
      "type": "object",
      "required": ["player_id", "name", "score", "rank", "at"],
      "properties": {
        "player_id": {"type": "string"},
        "name": {"type": "string"},
        "score": {"type": "integer", "minimum": 0},
        "rank": {"type": "integer", "minimum": 1},
        "at": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "Snapshot": {
      "type": "object",
      "required": ["type", "protocol_version", "server_tick", "players", "pipes_window", "leaderboard_topN"],
      "properties": {
        "type": {"const": "snapshot"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "server_tick": {"type": "integer", "minimum": 0},
        "players": {"type": "array", "items": {"$ref": "#/definitions/PlayerState"}, "maxItems": 100},
        "pipes_window": {"$ref": "#/definitions/PipesWindow"},
        "leaderboard_topN": {"type": "array", "items": {"$ref": "#/definitions/LeaderboardEntry"}, "maxItems": 10}
      },
      "additionalProperties": false
    },
    "RunStart": {
      "type": "object",
      "required": ["type", "protocol_version", "run_id", "room_id", "player_id", "start_time"],
      "properties": {
        "type": {"const": "runStart"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "run_id": {"type": "string"},
        "room_id": {"type": "string"},
        "player_id": {"type": "string"},
        "start_time": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "RunEnd": {
      "type": "object",
      "required": ["type", "protocol_version", "run_id", "end_time", "score", "cause"],
      "properties": {
        "type": {"const": "runEnd"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "run_id": {"type": "string"},
        "end_time": {"type": "integer", "minimum": 0},
        "score": {"type": "integer", "minimum": 0},
        "cause": {"type": "string", "enum": ["collision", "timeout", "disconnect", "server_shutdown"]}
      },
      "additionalProperties": false
    },
    "CapabilitiesRequest": {
      "type": "object",
      "required": ["type", "protocol_version"],
      "properties": {
        "type": {"const": "capabilities_request"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"}
      },
      "additionalProperties": false
    },
    "CapabilitiesResponse": {
      "type": "object",
      "required": ["type", "protocol_version", "supported_features"],
      "properties": {
        "type": {"const": "capabilities_response"},
        "protocol_version": {"$ref": "#/definitions/ProtocolVersion"},
        "supported_features": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      },
      "additionalProperties": false
    }
  }
}
