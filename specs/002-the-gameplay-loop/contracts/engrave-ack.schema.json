{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "engrave-ack.schema.json",
  "title": "EngraveAck",
  "type": "object",
  "required": ["type", "protocol_version", "run_id", "accepted"],
  "properties": {
    "type": { "const": "engraveAck" },
    "protocol_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "run_id": { "type": "string" },
    "accepted": { "type": "boolean" },
    "reason": {
      "type": "string",
      "enum": ["timeout", "filtered", "window-expired", "immutable"]
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 24 }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "accepted": { "const": true } } },
      "then": { "required": ["name"] }
    },
    {
      "if": { "properties": { "accepted": { "const": false } } },
      "then": { "required": ["reason"] }
    }
  ]
}
