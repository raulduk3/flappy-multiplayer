{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "ws", "jest"],
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "shared/*": ["../shared/src/*"]
    },
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*", "tests/**/*", "../shared/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
